# =============================================
# NEON POSTGRESQL (obtenha em console.neon.tech)
# =============================================

# URL com connection pooling (usada pelo app em produção)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# URL direta sem pooling (usada pelo prisma migrate)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# =============================================
# NEXTAUTH / AUTH.JS
# =============================================

# URL do seu app no Vercel (ex: https://meu-app.vercel.app)
NEXTAUTH_URL="https://seu-app.vercel.app"

# Gere com: openssl rand -hex 32
NEXTAUTH_SECRET="gere-um-segredo-forte-aqui"
AUTH_SECRET="gere-um-segredo-forte-aqui"
AUTH_TRUST_HOST=true

# =============================================
# JWT (tokens para ESP32)
# =============================================

JWT_SECRET="gere-um-segredo-forte-aqui"
JWT_EXPIRES_IN="10y"
